# ==========================================================
# LeadForge backend environment variables
# Copy to .env and fill in. Never commit .env.
# ==========================================================

# App
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000

# Database (Supabase Postgres — for local dev use the docker-compose Postgres)
DATABASE_URL=postgresql://postgres:password@localhost:5432/leadforge
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google
GOOGLE_PLACES_API_KEY=

# Outscraper (optional)
OUTSCRAPER_API_KEY=

# Anthropic
ANTHROPIC_API_KEY=
# Model for AI copy generation (default: claude-sonnet-5; use claude-opus-4-8 for higher quality)
ANTHROPIC_MODEL=claude-sonnet-5

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
SITE_BASE_DOMAIN=yourbrand.site

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=LeadForge
SMTP_FROM_EMAIL=outreach@yourdomain.com

# Redis
REDIS_URL=redis://localhost:6379

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Vapi
VAPI_API_KEY=
